pkgname=tidy-git
_pkgname=tidy
pkgver=2.0.0
pkgrel=1
pkgdesc='dotfile symlinker'
arch=('x86_64')
url="https://github.com/shrimp332/tidy"
license=('BSD-3-Clause')
makedepends=('git' 'go>=1.23' 'make')
options=(!debug)
source=("git+https://github.com/shrimp332/tidy.git")
md5sums=('SKIP')
conflicts=('tidy')

pkgver() {
    cd "${_pkgname}"
    git describe --tags | sed 's/-\([0-9]*\)-/.r\1./;s/v//'
}

build() {
    cd "${_pkgname}"
    make
}

package() {
    cd "${_pkgname}"
    install -Dm755 bin/"$_pkgname" "$pkgdir"/usr/bin/"$_pkgname"
    install -Dm755 completions/bash/"$_pkgname" $pkgdir"/usr/share/bash-completion/completions/$_pkgname"
    install -Dm755 completions/zsh/_"$_pkgname" $pkgdir"/usr/share/zsh/site-functions/_$_pkgname"
}
